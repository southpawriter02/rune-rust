<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RuneAndRust.DesktopUI.Views.CharacterCreationView"
             x:DataType="vm:CharacterCreationViewModel">

    <Design.DataContext>
        <vm:CharacterCreationViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Background="#1A1A1A">

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C2C2C" Padding="20,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Content="Back"
                        Command="{Binding BackCommand}"
                        Width="80"
                        HorizontalContentAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <Grid ColumnDefinitions="*,*" MaxWidth="1100" HorizontalAlignment="Center">

                <!-- Left Column: Name and Class Selection -->
                <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,20,0">

                    <!-- Character Name -->
                    <Border Background="#2C2C2C" Padding="20" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Character Name"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#4A90E2"/>
                            <TextBox Text="{Binding CharacterName}"
                                     FontSize="18"
                                     Watermark="Enter your name..."
                                     MaxLength="20"/>
                        </StackPanel>
                    </Border>

                    <!-- Class Selection -->
                    <Border Background="#2C2C2C" Padding="20" CornerRadius="8">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Choose Your Class"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#4A90E2"/>

                            <ItemsControl ItemsSource="{Binding AvailableClasses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,5"
                                                Padding="15"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding $parent[ItemsControl].((vm:CharacterCreationViewModel)DataContext).SelectClassCommand}"
                                                CommandParameter="{Binding Class}">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Icon -->
                                                <Border Grid.Column="0"
                                                        Background="#1A1A1A"
                                                        CornerRadius="4"
                                                        Padding="10"
                                                        Margin="0,0,15,0">
                                                    <TextBlock Text="{Binding IconText}"
                                                               FontSize="24"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Name and Description -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding ShortDescription}"
                                                               FontSize="12"
                                                               Foreground="#AAAAAA"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <!-- Stats -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <TextBlock FontSize="11" Foreground="#888888">
                                                        <Run Text="HP: "/>
                                                        <Run Text="{Binding HP}" Foreground="#FF6B6B"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="#888888">
                                                        <Run Text="STA: "/>
                                                        <Run Text="{Binding Stamina}" Foreground="#4A90E2"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Right Column: Class Details -->
                <Border Grid.Column="1" Background="#2C2C2C" Padding="20" CornerRadius="8" Margin="20,0,0,0">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Class Details"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#4A90E2"/>

                        <TextBlock Text="{Binding SelectedClass}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Border Background="#1A1A1A" Padding="15" CornerRadius="4">
                            <TextBlock Text="{Binding ClassDescription}"
                                       TextWrapping="Wrap"
                                       LineHeight="24"
                                       FontSize="14"
                                       Foreground="#CCCCCC"/>
                        </Border>

                        <TextBlock Text="Starting Equipment"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   Margin="0,10,0,0"/>

                        <TextBlock Text="Your starting equipment and abilities are determined by your class. You will be given basic gear appropriate to your playstyle."
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#AAAAAA"/>

                        <TextBlock Text="Tip"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"
                                   Margin="0,10,0,0"/>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#AAAAAA">
                            <Run Text="New players may want to start with the "/>
                            <Run Text="Warrior" FontWeight="Bold" Foreground="#DC143C"/>
                            <Run Text=" class for higher survivability, or "/>
                            <Run Text="Scavenger" FontWeight="Bold" Foreground="#4CAF50"/>
                            <Run Text=" for a balanced experience."/>
                        </TextBlock>

                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2C2C2C" Padding="20,15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Choose wisely - your class determines your starting abilities and playstyle."
                           Foreground="#888888"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Begin Adventure"
                        Command="{Binding StartGameCommand}"
                        IsEnabled="{Binding CanStartGame}"
                        Width="200"
                        Height="50"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#4A90E2"
                        HorizontalContentAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>

</UserControl>
