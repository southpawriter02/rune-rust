<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             xmlns:controls="using:RuneAndRust.DesktopUI.Controls"
             xmlns:converters="using:RuneAndRust.DesktopUI.Converters"
             x:Class="RuneAndRust.DesktopUI.Views.DungeonExplorationView"
             x:DataType="vm:DungeonExplorationViewModel">

    <Design.DataContext>
        <vm:DungeonExplorationViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <converters:NotNullToBoolConverter x:Key="NotNullConverter"/>
        <converters:CountToBoolConverter x:Key="CountToBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Exit button style -->
        <Style Selector="Button.ExitButton">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Action button style -->
        <Style Selector="Button.ActionButton">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Feature card style -->
        <Style Selector="Border.FeatureCard">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <!-- Overlay dialog styles -->
        <Style Selector="Border.DialogOverlay">
            <Setter Property="Background" Value="#E0000000"/>
        </Style>
        <Style Selector="Border.DialogBox">
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="MaxWidth" Value="500"/>
        </Style>
        <Style Selector="Button.DialogButton">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="15,8"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- Main Content Grid -->
        <Grid ColumnDefinitions="*,280,Auto" Margin="15">
            <!-- Main Room Display -->
        <Border Grid.Column="0"
                Background="#2C2C2C"
                Padding="20"
                Margin="0,0,10,0"
                CornerRadius="8">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Room Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <!-- Biome & Layer -->
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                        <Border Background="{Binding BiomeColor}"
                                CornerRadius="4"
                                Padding="8,3">
                            <TextBlock Text="{Binding BiomeName}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                        <TextBlock Text="{Binding LayerDisplay}"
                                   FontSize="11"
                                   Foreground="#888888"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Room Name -->
                    <TextBlock Text="{Binding RoomName}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <!-- Hazard Warning -->
                    <Border Background="#8B0000"
                            CornerRadius="4"
                            Padding="10,5"
                            Margin="0,8,0,0"
                            IsVisible="{Binding HazardWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="!" FontWeight="Bold" Foreground="#FF6B6B"/>
                            <TextBlock Text="{Binding HazardWarning}"
                                       Foreground="#FF6B6B"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Room Content -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="15">
                        <!-- Room Description -->
                        <TextBlock Text="{Binding RoomDescription}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="#DDDDDD"
                                   LineHeight="22"/>

                        <!-- Room Features -->
                        <Border Background="#1C1C1C"
                                Padding="12"
                                CornerRadius="6"
                                IsVisible="{Binding RoomFeatures.Count}">
                            <StackPanel>
                                <TextBlock Text="Features"
                                           FontWeight="Bold"
                                           Foreground="#4A90E2"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding RoomFeatures}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:RoomFeatureViewModel">
                                            <Border Classes="FeatureCard">
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <!-- Icon -->
                                                    <Border Grid.Column="0"
                                                            Width="28"
                                                            Height="28"
                                                            CornerRadius="4"
                                                            Background="#3C3C3C"
                                                            Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Icon}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="Bold"/>
                                                    </Border>

                                                    <!-- Text -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Foreground="#AAAAAA"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <!-- Interact button -->
                                                    <Button Grid.Column="2"
                                                            Content="Interact"
                                                            Command="{Binding $parent[UserControl].((vm:DungeonExplorationViewModel)DataContext).InteractCommand}"
                                                            CommandParameter="{Binding}"
                                                            IsVisible="{Binding IsInteractable}"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Available Exits -->
                        <Border Background="#1C1C1C"
                                Padding="12"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Exits"
                                           FontWeight="Bold"
                                           Foreground="#4A90E2"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding AvailableExits}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ExitViewModel">
                                            <Button Classes="ExitButton"
                                                    Command="{Binding $parent[UserControl].((vm:DungeonExplorationViewModel)DataContext).MoveCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding TraversalRequirements}"
                                                               FontSize="10"
                                                               Foreground="#888888"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding IsVertical}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No exits available"
                                           FontStyle="Italic"
                                           Foreground="#666666"
                                           IsVisible="{Binding !AvailableExits.Count}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Status Bar -->
                <Border Grid.Row="2"
                        Background="#1C1C1C"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,10,0,0"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="#4CAF50"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- Actions Sidebar -->
        <Border Grid.Column="1"
                Background="#2C2C2C"
                Padding="15"
                CornerRadius="8">
            <StackPanel Spacing="8">
                <!-- Character Stats -->
                <TextBlock Text="Status"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <Border Background="#1C1C1C" CornerRadius="4" Padding="10">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                        <!-- HP -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="HP:"
                                   Foreground="#888888"
                                   Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding HPDisplay}"
                                   Foreground="#4CAF50"
                                   FontWeight="Bold"/>

                        <!-- Stamina -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Stamina:"
                                   Foreground="#888888"
                                   Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding StaminaDisplay}"
                                   Foreground="#4A90E2"
                                   FontWeight="Bold"/>

                        <!-- Stress -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Stress:"
                                   Foreground="#888888"
                                   Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding StressDisplay}"
                                   Foreground="#FF6B6B"
                                   FontWeight="Bold"/>
                    </Grid>
                </Border>

                <Separator Background="#3C3C3C" Margin="0,8"/>

                <!-- Actions -->
                <TextBlock Text="Actions"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <!-- Search Room -->
                <Button Classes="ActionButton"
                        Command="{Binding SearchRoomCommand}"
                        IsEnabled="{Binding !IsSearched}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Search Room" FontWeight="SemiBold"/>
                        <TextBlock Text="(S)" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Rest -->
                <Button Classes="ActionButton"
                        Command="{Binding RestCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Rest" FontWeight="SemiBold"/>
                        <TextBlock Text="(R)" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Engage (if enemies present) -->
                <Button Classes="ActionButton"
                        Command="{Binding EngageCommand}"
                        IsVisible="{Binding HasEnemies}"
                        Background="#8B0000">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Engage Enemies" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="!" Foreground="#FF6B6B" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <Separator Background="#3C3C3C" Margin="0,8"/>

                <!-- Quick Access -->
                <TextBlock Text="Quick Access"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <!-- Character Sheet -->
                <Button Classes="ActionButton"
                        Command="{Binding ViewCharacterCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Character" FontWeight="SemiBold"/>
                        <TextBlock Text="(C)" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Inventory -->
                <Button Classes="ActionButton"
                        Command="{Binding ViewInventoryCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Inventory" FontWeight="SemiBold"/>
                        <TextBlock Text="(I)" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Toggle Map -->
                <Button Classes="ActionButton"
                        Command="{Binding ToggleMinimapCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Map" FontWeight="SemiBold"/>
                        <TextBlock Text="(M)" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Sanctuary indicator -->
                <Border Background="#2E4A2E"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,10,0,0"
                        IsVisible="{Binding IsSanctuary}">
                    <StackPanel>
                        <TextBlock Text="Sanctuary"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Safe to rest here"
                                   FontSize="10"
                                   Foreground="#88CC88"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Minimap Panel (Column 2) -->
        <Border Grid.Column="2"
                Width="300"
                Margin="10,0,0,0"
                IsVisible="{Binding IsMinimapVisible}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header with layer info -->
                <Border Grid.Row="0"
                        Background="#2C2C2C"
                        Padding="10,8"
                        CornerRadius="6,6,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <!-- Layer Information -->
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Dungeon Map"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Minimap.LayerDisplayName}"
                                           FontSize="12"
                                           Foreground="#4A90E2"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Minimap.LayerDepthDisplay}"
                                           FontSize="10"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Layer Navigation -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <Button Width="28" Height="24"
                                    Padding="0"
                                    Background="#3C3C3C"
                                    Command="{Binding Minimap.LayerUpCommand}"
                                    IsEnabled="{Binding Minimap.CanGoUp}"
                                    ToolTip.Tip="Go to higher layer">
                                <TextBlock Text="^" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Width="28" Height="24"
                                    Padding="0"
                                    Background="#3C3C3C"
                                    Command="{Binding Minimap.LayerDownCommand}"
                                    IsEnabled="{Binding Minimap.CanGoDown}"
                                    ToolTip.Tip="Go to lower layer">
                                <TextBlock Text="v" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Minimap Canvas -->
                <Border Grid.Row="1"
                        Background="#1C1C1C"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1"
                        ClipToBounds="True"
                        MinHeight="250">
                    <Grid>
                        <!-- The custom minimap control -->
                        <controls:MinimapControl ViewModel="{Binding Minimap}"
                                                 RoomSize="40"/>

                        <!-- Zoom Controls Overlay (top-left) -->
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="6"
                                    Spacing="3">
                            <Button Width="24" Height="24"
                                    Padding="0"
                                    Background="#2C2C2CCC"
                                    Command="{Binding Minimap.ZoomInCommand}"
                                    ToolTip.Tip="Zoom In">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Width="24" Height="24"
                                    Padding="0"
                                    Background="#2C2C2CCC"
                                    Command="{Binding Minimap.ZoomOutCommand}"
                                    ToolTip.Tip="Zoom Out">
                                <TextBlock Text="-" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Width="24" Height="24"
                                    Padding="0"
                                    Background="#2C2C2CCC"
                                    Command="{Binding Minimap.CenterOnPlayerCommand}"
                                    ToolTip.Tip="Center on Player">
                                <TextBlock Text="C" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <!-- Legend Overlay (bottom-left) -->
                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Background="#2C2C2CCC"
                                CornerRadius="4"
                                Padding="6"
                                Margin="6">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Legend"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="#888888"
                                           Margin="0,0,0,2"/>

                                <!-- Current Room -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Border Width="10" Height="10"
                                            Background="#4A4A4A"
                                            BorderBrush="#FFD700"
                                            BorderThickness="2"
                                            CornerRadius="2"/>
                                    <TextBlock Text="Current" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Vertical Indicators -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="^" FontWeight="Bold" FontSize="10" Foreground="#FFFF00" Width="10" TextAlignment="Center"/>
                                    <TextBlock Text="Up" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                    <TextBlock Text="v" FontWeight="Bold" FontSize="10" Foreground="#00FFFF" Width="10" TextAlignment="Center" Margin="4,0,0,0"/>
                                    <TextBlock Text="Down" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Footer with exploration progress -->
                <Border Grid.Row="2"
                        Background="#2C2C2C"
                        Padding="8,4"
                        CornerRadius="0,0,6,6">
                    <TextBlock Text="{Binding Minimap.ExplorationProgress}"
                               FontSize="10"
                               Foreground="#888888"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
        </Grid>

        <!-- ==================== SEARCH RESULT OVERLAY ==================== -->
        <Border Classes="DialogOverlay"
                IsVisible="{Binding SearchResult, Converter={StaticResource NotNullConverter}}">
            <Border Classes="DialogBox"
                    BorderBrush="{Binding SearchResult.TitleColor}"
                    BorderThickness="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel Spacing="15" MinWidth="400">
                    <!-- Title -->
                    <TextBlock Text="{Binding SearchResult.ResultTitle}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{Binding SearchResult.TitleColor}"
                               HorizontalAlignment="Center"/>

                    <!-- Found Loot Section -->
                    <StackPanel IsVisible="{Binding SearchResult.FoundLoot}" Spacing="10">
                        <TextBlock Text="Found Items:"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <ItemsControl ItemsSource="{Binding SearchResult.LootItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:LootItemViewModel">
                                    <Border Background="#1C1C1C"
                                            Padding="10"
                                            Margin="0,4"
                                            CornerRadius="5"
                                            BorderBrush="{Binding QualityColor}"
                                            BorderThickness="1">
                                        <Grid ColumnDefinitions="40,*">
                                            <!-- Item Icon -->
                                            <Border Grid.Column="0"
                                                    Width="36"
                                                    Height="36"
                                                    Background="#2C2C2C"
                                                    CornerRadius="4"
                                                    BorderBrush="{Binding QualityColor}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding QualityColor}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Item Info -->
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding QualityName}"
                                                               FontSize="10"
                                                               Foreground="{Binding QualityColor}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="#AAAAAA"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding TypeDisplay}"
                                                           FontSize="10"
                                                           Foreground="#666666"
                                                           FontStyle="Italic"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Discovered Secrets Section -->
                    <StackPanel IsVisible="{Binding SearchResult.DiscoveredSecrets.Count, Converter={StaticResource CountToBoolConverter}}"
                                Spacing="5">
                        <TextBlock Text="Discovered:"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#9400D3"/>

                        <ItemsControl ItemsSource="{Binding SearchResult.DiscoveredSecrets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A2E"
                                            Padding="10"
                                            Margin="0,2"
                                            CornerRadius="4">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#CCCCCC"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Encounter Warning -->
                    <Border IsVisible="{Binding SearchResult.TriggeredEncounter}"
                            Background="#8B0000"
                            Padding="12"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="COMBAT ENCOUNTER!"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SearchResult.EncounterDescription}"
                                       FontSize="12"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Nothing Found Message -->
                    <TextBlock Text="You search thoroughly but find nothing of interest."
                               Foreground="#888888"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               IsVisible="{Binding SearchResult.NothingFound}"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="10"
                                Margin="0,10,0,0">
                        <!-- Collect Loot Button -->
                        <Button Classes="DialogButton"
                                Content="Collect Loot"
                                Command="{Binding CollectLootCommand}"
                                IsVisible="{Binding SearchResult.FoundLoot}"
                                Background="#4CAF50"/>

                        <!-- Close/Continue Button -->
                        <Button Classes="DialogButton"
                                Command="{Binding CloseSearchResultCommand}">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="SearchResult.TriggeredEncounter"
                                                     Converter="{x:Static BoolConverters.Not}"
                                                     FallbackValue="Close"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ==================== REST CONFIRMATION DIALOG ==================== -->
        <Border Classes="DialogOverlay"
                IsVisible="{Binding IsRestDialogVisible}">
            <Border Classes="DialogBox"
                    BorderBrush="{Binding RestConfirmation.TitleColor}"
                    BorderThickness="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel Spacing="15" MinWidth="380">
                    <!-- Title -->
                    <TextBlock Text="{Binding RestConfirmation.Title}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{Binding RestConfirmation.TitleColor}"/>

                    <TextBlock Text="Rest to recover HP and Stamina?"
                               TextWrapping="Wrap"
                               Foreground="#CCCCCC"/>

                    <!-- Sanctuary Indicator -->
                    <Border Background="#2E4A2E"
                            Padding="10"
                            CornerRadius="5"
                            IsVisible="{Binding RestConfirmation.IsSanctuary}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="+"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="#4CAF50"/>
                            <TextBlock Text="This is a sanctuary - safe to rest here!"
                                       Foreground="#4CAF50"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Warnings (Non-Sanctuary) -->
                    <Border Background="#3D2B1F"
                            Padding="10"
                            CornerRadius="5"
                            IsVisible="{Binding !RestConfirmation.IsSanctuary}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Warnings:"
                                       FontWeight="Bold"
                                       Foreground="#FF9800"/>
                            <ItemsControl ItemsSource="{Binding RestConfirmation.Warnings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="!"
                                                       Foreground="#FF9800"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#CCCCCC"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recovery Info -->
                    <Border Background="#1C1C1C"
                            Padding="12"
                            CornerRadius="5">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Recovery:"
                                       FontWeight="Bold"
                                       Foreground="#4A90E2"/>

                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="HP:"
                                           Foreground="#888888"
                                           Margin="0,0,10,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding RestConfirmation.HPRecovery}"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Stamina:"
                                           Foreground="#888888"
                                           Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding RestConfirmation.StaminaRecovery}"
                                           Foreground="#4A90E2"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="10"
                                Margin="0,5,0,0">
                        <Button Classes="DialogButton"
                                Content="Rest"
                                Command="{Binding ConfirmRestCommand}"
                                Background="#4CAF50"/>
                        <Button Classes="DialogButton"
                                Content="Cancel"
                                Command="{Binding CancelRestCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ==================== SEARCHING INDICATOR ==================== -->
        <Border Classes="DialogOverlay"
                IsVisible="{Binding IsSearching}">
            <Border Background="#2C2C2C"
                    CornerRadius="10"
                    Padding="30"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel Spacing="15" HorizontalAlignment="Center">
                    <TextBlock Text="Searching..."
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"
                                 Width="200"
                                 Height="6"/>
                    <TextBlock Text="Examining the area carefully..."
                               FontSize="12"
                               Foreground="#888888"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
