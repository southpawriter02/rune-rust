<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             xmlns:controls="using:RuneAndRust.DesktopUI.Controls"
             x:Class="RuneAndRust.DesktopUI.Views.MinimapView"
             x:DataType="vm:MinimapViewModel">

    <Design.DataContext>
        <vm:MinimapViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Control button style -->
        <Style Selector="Button.ControlButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.ControlButton:pointerover">
            <Setter Property="Background" Value="#3C3C3C"/>
        </Style>

        <!-- Layer button style -->
        <Style Selector="Button.LayerButton">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.LayerButton:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header with layer info -->
        <Border Grid.Row="0"
                Background="#2C2C2C"
                Padding="10,8"
                CornerRadius="6,6,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Layer Information -->
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Dungeon Map"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding LayerDisplayName}"
                                   FontSize="12"
                                   Foreground="#4A90E2"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LayerDepthDisplay}"
                                   FontSize="10"
                                   Foreground="#888888"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Layer Navigation -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button Classes="LayerButton"
                            Command="{Binding LayerUpCommand}"
                            IsEnabled="{Binding CanGoUp}"
                            ToolTip.Tip="Go to higher layer">
                        <TextBlock Text="^" FontWeight="Bold"/>
                    </Button>
                    <Button Classes="LayerButton"
                            Command="{Binding LayerDownCommand}"
                            IsEnabled="{Binding CanGoDown}"
                            ToolTip.Tip="Go to lower layer">
                        <TextBlock Text="v" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Minimap Canvas -->
        <Border Grid.Row="1"
                Background="#1C1C1C"
                BorderBrush="#3C3C3C"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <!-- The custom minimap control -->
                <controls:MinimapControl ViewModel="{Binding}"
                                         RoomSize="40"/>

                <!-- Zoom Controls Overlay (top-left) -->
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8"
                            Spacing="4">
                    <Button Classes="ControlButton"
                            Command="{Binding ZoomInCommand}"
                            ToolTip.Tip="Zoom In (Scroll Up)">
                        <TextBlock Text="+" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Classes="ControlButton"
                            Command="{Binding ZoomOutCommand}"
                            ToolTip.Tip="Zoom Out (Scroll Down)">
                        <TextBlock Text="-" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Classes="ControlButton"
                            Command="{Binding ResetViewCommand}"
                            ToolTip.Tip="Reset View">
                        <TextBlock Text="R" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Classes="ControlButton"
                            Command="{Binding CenterOnPlayerCommand}"
                            ToolTip.Tip="Center on Player">
                        <TextBlock Text="C" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Legend Overlay (bottom-left) -->
                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="#2C2C2CCC"
                        CornerRadius="4"
                        Padding="8"
                        Margin="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Legend"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#888888"
                                   Margin="0,0,0,4"/>

                        <!-- Current Room -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="12" Height="12"
                                    Background="#4A4A4A"
                                    BorderBrush="#FFD700"
                                    BorderThickness="2"
                                    CornerRadius="2"/>
                            <TextBlock Text="Current" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Start Room -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="12" Height="12"
                                    Background="#4CAF50"
                                    CornerRadius="2"/>
                            <TextBlock Text="Start" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Boss Room -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="12" Height="12"
                                    Background="#8B0000"
                                    CornerRadius="2"/>
                            <TextBlock Text="Boss" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Sanctuary -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="12" Height="12"
                                    Background="#2E4A2E"
                                    CornerRadius="2"/>
                            <TextBlock Text="Sanctuary" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Vertical Indicators -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <Border Width="12" Height="12" Background="Transparent">
                                <TextBlock Text="^"
                                           FontWeight="Bold"
                                           FontSize="10"
                                           Foreground="#FFFF00"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Up" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="12" Height="12" Background="Transparent">
                                <TextBlock Text="v"
                                           FontWeight="Bold"
                                           FontSize="10"
                                           Foreground="#00FFFF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Down" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Fog of War -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="12" Height="12"
                                    Background="#33333380"
                                    CornerRadius="2">
                                <TextBlock Text="?"
                                           FontSize="8"
                                           Foreground="#666666"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Unexplored" FontSize="9" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Zoom Level Indicator (bottom-right) -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#2C2C2CCC"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="8">
                    <TextBlock FontSize="10" Foreground="#888888">
                        <Run Text="Zoom: "/>
                        <Run Text="{Binding ZoomLevel, StringFormat={}{0:P0}}"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- Footer with exploration progress -->
        <Border Grid.Row="2"
                Background="#2C2C2C"
                Padding="10,6"
                CornerRadius="0,0,6,6">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Exploration Progress -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ExplorationProgress}"
                           FontSize="11"
                           Foreground="#888888"
                           VerticalAlignment="Center"/>

                <!-- Pan Hint -->
                <TextBlock Grid.Column="1"
                           Text="Ctrl+Drag or Middle-Click to pan"
                           FontSize="9"
                           Foreground="#555555"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
