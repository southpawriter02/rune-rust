<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             xmlns:controls="using:RuneAndRust.DesktopUI.Controls"
             x:Class="RuneAndRust.DesktopUI.Views.CombatView"
             x:DataType="vm:CombatViewModel">

    <Design.DataContext>
        <vm:CombatViewModel/>
    </Design.DataContext>

    <!-- v0.43.17: Panel wrapper for boss overlay support -->
    <Panel>
        <!-- v0.43.17: Boss Overlay (displays above combat when boss fight active) -->
        <controls:BossOverlayControl DataContext="{Binding BossCombatViewModel}"
                                     IsVisible="{Binding IsBossFight}"
                                     ZIndex="10"/>

        <!-- Main Layout: Combat Grid + Turn Order top, Actions + Log bottom -->
        <Grid RowDefinitions="*,200" ColumnDefinitions="*,250" Margin="10">

        <!-- Combat Grid (Top Left) -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="#1a1a1a"
                BorderBrush="#333333"
                BorderThickness="2"
                CornerRadius="8"
                Margin="0,0,10,10"
                Padding="20">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="{Binding Title}"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           Margin="0,0,0,15"/>

                <!-- Grid Control -->
                <controls:CombatGridControl Grid.Row="1"
                    x:Name="CombatGridControl"
                    Columns="{Binding Columns}"
                    CellSize="{Binding CellSize}"
                    SelectedPosition="{Binding SelectedPosition}"
                    HoveredPosition="{Binding HoveredPosition}"
                    HighlightedPositions="{Binding HighlightedPositions}"
                    UnitSprites="{Binding UnitSprites}"
                    UnitData="{Binding UnitData}"
                    StatusEffectIconService="{Binding StatusEffectIconService}"
                    Grid="{Binding Grid}"
                    EnvironmentalObjects="{Binding EnvironmentalObjects}"
                    HazardVisualizationService="{Binding HazardVisualizationService}"
                    AnimationService="{Binding AnimationService}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <!-- Status Message -->
                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           FontSize="14"
                           Foreground="#cccccc"
                           TextAlignment="Center"
                           Margin="0,15,0,0"/>
            </Grid>
        </Border>

        <!-- Turn Order (Top Right) -->
        <Border Grid.Row="0" Grid.Column="1"
                Background="#1a1a1a"
                BorderBrush="#333333"
                BorderThickness="2"
                CornerRadius="8"
                Margin="0,0,0,10"
                Padding="15">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Turn Order"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TurnOrder}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8"
                                        Margin="0,2"
                                        CornerRadius="4"
                                        Background="#2a2a2a">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               Foreground="#cccccc"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Action Menu (Bottom Left) -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#1a1a1a"
                BorderBrush="#333333"
                BorderThickness="2"
                CornerRadius="8"
                Margin="0,0,10,0"
                Padding="15">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Combat Actions"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Command="{Binding AttackCommand}"
                            Content="⚔️ Attack (1)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>

                    <Button Command="{Binding DefendCommand}"
                            Content="🛡️ Defend (2)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>

                    <Button Command="{Binding UseAbilityCommand}"
                            Content="✨ Ability (3)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>

                    <Button Command="{Binding UseItemCommand}"
                            Content="🧪 Item (4)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>

                    <Button Command="{Binding MoveCommand}"
                            Content="👣 Move (5)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>

                    <Button Command="{Binding EndTurnCommand}"
                            Content="⏭️ End Turn (Space)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>

                    <Button Command="{Binding FleeCommand}"
                            Content="🏃 Flee (F)"
                            Width="140"
                            Height="50"
                            Margin="5"
                            FontSize="14"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Combat Log (Bottom Right) -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#1a1a1a"
                BorderBrush="#333333"
                BorderThickness="2"
                CornerRadius="8"
                Padding="15">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Combat Log"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CombatLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="12"
                                           Foreground="#cccccc"
                                           TextWrapping="Wrap"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>
    </Panel>

</UserControl>
