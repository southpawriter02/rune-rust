<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             xmlns:converters="using:RuneAndRust.DesktopUI.Converters"
             x:Class="RuneAndRust.DesktopUI.Views.SpecializationTreeView"
             x:DataType="vm:SpecializationTreeViewModel">

    <Design.DataContext>
        <vm:SpecializationTreeViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Tier section style -->
        <Style Selector="Border.TierSection">
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Tier header style -->
        <Style Selector="TextBlock.TierHeader">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Ability card style -->
        <Style Selector="Border.AbilityCard">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Action button style -->
        <Style Selector="Button.ActionButton">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Header: Specialization Info + PP Display -->
        <Border Grid.Row="0"
                Background="#2C2C2C"
                Padding="20"
                Margin="0,0,0,15"
                CornerRadius="8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Specialization Icon -->
                <Border Grid.Column="0"
                        Background="#3C3C3C"
                        CornerRadius="8"
                        Width="60"
                        Height="60"
                        Margin="0,0,15,0">
                    <TextBlock Text="{Binding SpecializationIcon}"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Specialization Details -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SpecializationName}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FFD700"/>
                    <TextBlock Text="{Binding SpecializationTagline}"
                               FontSize="12"
                               FontStyle="Italic"
                               Foreground="#AAAAAA"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding SpecializationDescription}"
                               FontSize="12"
                               Foreground="#CCCCCC"
                               TextWrapping="Wrap"
                               MaxWidth="600"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- PP Display -->
                <Border Grid.Column="2"
                        Background="#3C3C3C"
                        CornerRadius="8"
                        Padding="20,10"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Progression Points"
                                   FontSize="11"
                                   Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AvailablePP}"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#4A90E2"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <TextBlock Text="Spent in tree: "
                                       FontSize="10"
                                       Foreground="#888888"/>
                            <TextBlock Text="{Binding PPSpentInTree}"
                                       FontSize="10"
                                       Foreground="#4A90E2"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Ability Tree -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="0">

                <!-- Foundation Tier (Tier 1) -->
                <Border Classes="TierSection">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#4A90E2" CornerRadius="4" Padding="8,2">
                                <TextBlock Text="TIER 1" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Foundation" Classes="TierHeader" Foreground="#4A90E2"/>
                        </StackPanel>
                        <TextBlock Text="Basic abilities that form the foundation of your specialization."
                                   FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding FoundationTier}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AbilityNodeViewModel">
                                    <Border Classes="AbilityCard"
                                            Background="{Binding BackgroundColor}"
                                            BorderBrush="{Binding BorderColor}"
                                            ToolTip.Tip="{Binding MechanicalSummary}">
                                        <StackPanel>
                                            <!-- Header -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1"
                                                        Background="#4A90E2"
                                                        CornerRadius="3"
                                                        Padding="4,1">
                                                    <TextBlock Text="{Binding AbilityType}"
                                                               FontSize="9"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10"
                                                       Foreground="#BBBBBB"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       Margin="0,5,0,0"/>

                                            <!-- Stats -->
                                            <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Rank" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding RankDisplay}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#4CAF50"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Cost" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding ResourceCostText}"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Prerequisites -->
                                            <TextBlock Text="{Binding PrerequisiteText}"
                                                       FontSize="9"
                                                       FontStyle="Italic"
                                                       Foreground="#777777"
                                                       Margin="0,5,0,0"/>

                                            <!-- Action Button -->
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).UnlockAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding !IsUnlocked}"
                                                    IsEnabled="{Binding CanUnlock}"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).RankUpAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding IsUnlocked}"
                                                    IsEnabled="{Binding CanRankUp}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Core Tier (Tier 2) -->
                <Border Classes="TierSection">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#FFD700" CornerRadius="4" Padding="8,2">
                                <TextBlock Text="TIER 2" FontSize="10" FontWeight="Bold" Foreground="#1A1A1A"/>
                            </Border>
                            <TextBlock Text="Core" Classes="TierHeader" Foreground="#FFD700"/>
                        </StackPanel>
                        <TextBlock Text="Core abilities that define your combat style. Requires 6+ PP spent in tree."
                                   FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding CoreTier}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AbilityNodeViewModel">
                                    <Border Classes="AbilityCard"
                                            Background="{Binding BackgroundColor}"
                                            BorderBrush="{Binding BorderColor}"
                                            ToolTip.Tip="{Binding MechanicalSummary}">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1"
                                                        Background="#FFD700"
                                                        CornerRadius="3"
                                                        Padding="4,1">
                                                    <TextBlock Text="{Binding AbilityType}"
                                                               FontSize="9"
                                                               Foreground="#1A1A1A"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10"
                                                       Foreground="#BBBBBB"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       Margin="0,5,0,0"/>
                                            <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Rank" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding RankDisplay}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#4CAF50"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Cost" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding ResourceCostText}"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding PrerequisiteText}"
                                                       FontSize="9"
                                                       FontStyle="Italic"
                                                       Foreground="#777777"
                                                       Margin="0,5,0,0"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).UnlockAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding !IsUnlocked}"
                                                    IsEnabled="{Binding CanUnlock}"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).RankUpAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding IsUnlocked}"
                                                    IsEnabled="{Binding CanRankUp}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Advanced Tier (Tier 3) -->
                <Border Classes="TierSection">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#9400D3" CornerRadius="4" Padding="8,2">
                                <TextBlock Text="TIER 3" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Advanced" Classes="TierHeader" Foreground="#9400D3"/>
                        </StackPanel>
                        <TextBlock Text="Powerful abilities for experienced warriors. Requires 15+ PP spent in tree."
                                   FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding AdvancedTier}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AbilityNodeViewModel">
                                    <Border Classes="AbilityCard"
                                            Background="{Binding BackgroundColor}"
                                            BorderBrush="{Binding BorderColor}"
                                            ToolTip.Tip="{Binding MechanicalSummary}">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1"
                                                        Background="#9400D3"
                                                        CornerRadius="3"
                                                        Padding="4,1">
                                                    <TextBlock Text="{Binding AbilityType}"
                                                               FontSize="9"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10"
                                                       Foreground="#BBBBBB"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       Margin="0,5,0,0"/>
                                            <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Rank" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding RankDisplay}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#4CAF50"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Cost" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding ResourceCostText}"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding PrerequisiteText}"
                                                       FontSize="9"
                                                       FontStyle="Italic"
                                                       Foreground="#777777"
                                                       Margin="0,5,0,0"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).UnlockAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding !IsUnlocked}"
                                                    IsEnabled="{Binding CanUnlock}"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).RankUpAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding IsUnlocked}"
                                                    IsEnabled="{Binding CanRankUp}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Mastery Tier (Tier 4) -->
                <Border Classes="TierSection">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#DC143C" CornerRadius="4" Padding="8,2">
                                <TextBlock Text="TIER 4" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Mastery" Classes="TierHeader" Foreground="#DC143C"/>
                        </StackPanel>
                        <TextBlock Text="Ultimate abilities that represent the pinnacle of your specialization. Requires 24+ PP spent in tree."
                                   FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding MasteryTier}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AbilityNodeViewModel">
                                    <Border Classes="AbilityCard"
                                            Background="{Binding BackgroundColor}"
                                            BorderBrush="{Binding BorderColor}"
                                            ToolTip.Tip="{Binding MechanicalSummary}">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1"
                                                        Background="#DC143C"
                                                        CornerRadius="3"
                                                        Padding="4,1">
                                                    <TextBlock Text="{Binding AbilityType}"
                                                               FontSize="9"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10"
                                                       Foreground="#BBBBBB"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       Margin="0,5,0,0"/>
                                            <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Rank" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding RankDisplay}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#4CAF50"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Cost" FontSize="9" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding ResourceCostText}"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding PrerequisiteText}"
                                                       FontSize="9"
                                                       FontStyle="Italic"
                                                       Foreground="#777777"
                                                       Margin="0,5,0,0"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).UnlockAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding !IsUnlocked}"
                                                    IsEnabled="{Binding CanUnlock}"/>
                                            <Button Classes="ActionButton"
                                                    Content="{Binding ActionButtonText}"
                                                    Command="{Binding $parent[UserControl].((vm:SpecializationTreeViewModel)DataContext).RankUpAbilityCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding IsUnlocked}"
                                                    IsEnabled="{Binding CanRankUp}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="#2C2C2C"
                Padding="15,10"
                Margin="0,10,0,0"
                CornerRadius="8"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="#4CAF50"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
