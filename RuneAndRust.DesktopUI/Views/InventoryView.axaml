<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             xmlns:converters="using:RuneAndRust.DesktopUI.Converters"
             x:Class="RuneAndRust.DesktopUI.Views.InventoryView"
             x:DataType="vm:InventoryViewModel">

    <Design.DataContext>
        <vm:InventoryViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Section Header Style -->
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Item Card Style -->
        <Style Selector="Border.ItemCard">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Border.ItemCard:pointerover">
            <Setter Property="BorderBrush" Value="#6A6A6A"/>
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>

        <!-- Equipment Slot Style -->
        <Style Selector="Border.EquipSlot">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="BorderBrush" Value="#4A90E2"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <Style Selector="Border.EquipSlot:pointerover">
            <Setter Property="BorderBrush" Value="#6AB0FF"/>
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>

        <!-- Section Border Style -->
        <Style Selector="Border.Section">
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- Button Styles -->
        <Style Selector="Button.ActionBtn">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style Selector="Button.EquipBtn">
            <Setter Property="Background" Value="#228B22"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.UnequipBtn">
            <Setter Property="Background" Value="#DC143C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.UseBtn">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.DropBtn">
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.SortBtn">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="320,*" Margin="20">

        <!-- Left Panel: Equipment Slots -->
        <Border Grid.Column="0" Classes="Section" Margin="0,0,10,0">
            <StackPanel Spacing="15">
                <TextBlock Text="Equipment" Classes="SectionHeader"/>

                <!-- Equipment Slots -->
                <ItemsControl ItemsSource="{Binding EquipmentSlots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="EquipSlot">
                                <Grid ColumnDefinitions="50,*,Auto">
                                    <!-- Slot Icon -->
                                    <Border Grid.Column="0"
                                            Background="#3C3C3C"
                                            Width="50"
                                            Height="50"
                                            CornerRadius="6">
                                        <TextBlock Text="{Binding SlotIcon}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#888888"/>
                                    </Border>

                                    <!-- Slot Info -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="Bold"
                                                   Foreground="#AAAAAA"
                                                   FontSize="11"/>

                                        <TextBlock Text="{Binding EquippedItemName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{Binding EquippedItem.QualityColor, FallbackValue=#666666}"
                                                   Margin="0,2,0,0"/>

                                        <TextBlock Text="{Binding EquippedItemStats}"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Unequip Button -->
                                    <Button Grid.Column="2"
                                            Content="Unequip"
                                            Classes="ActionBtn UnequipBtn"
                                            Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).UnequipSlotCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding !IsEmpty}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Comparison Panel -->
                <Border Background="#1C1C1C"
                        Padding="12"
                        CornerRadius="6"
                        IsVisible="{Binding CurrentComparison, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Comparison" FontWeight="Bold" Foreground="#FFD700"/>

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding CurrentComparison.IsUpgrade, Converter={x:Static converters:BoolToUpgradeConverter.Instance}}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CurrentComparison.Differences}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#CCCCCC"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="#4A90E2"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Right Panel: Inventory Grid -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,*">

            <!-- Equipment Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Equipment" Classes="SectionHeader" Margin="0"/>
                    <TextBlock Text="{Binding InventoryCountDisplay}"
                               FontSize="14"
                               Foreground="#888888"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Sort:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button Content="Type" Classes="SortBtn" Command="{Binding SortByTypeCommand}"/>
                    <Button Content="Quality" Classes="SortBtn" Command="{Binding SortByQualityCommand}"/>
                    <Button Content="Name" Classes="SortBtn" Command="{Binding SortByNameCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Equipment Grid -->
            <Border Grid.Row="1" Classes="Section">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding EquipmentItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="ItemCard" Width="200">
                                    <StackPanel Spacing="6">
                                        <!-- Item Header -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Background="#3C3C3C"
                                                    Width="32"
                                                    Height="32"
                                                    CornerRadius="4">
                                                <TextBlock Text="{Binding SlotIcon}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding QualityColor}"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="12"
                                                           Foreground="{Binding QualityColor}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TypeDisplay}"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Stats -->
                                        <TextBlock Text="{Binding StatsSummary}"
                                                   FontSize="11"
                                                   Foreground="#CCCCCC"/>

                                        <!-- Bonuses -->
                                        <TextBlock Text="{Binding BonusesDisplay}"
                                                   FontSize="10"
                                                   Foreground="#4A90E2"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding HasSpecialEffect}"/>

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,4,0,0">
                                            <Button Content="Equip"
                                                    Classes="ActionBtn EquipBtn"
                                                    Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).EquipItemCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Drop"
                                                    Classes="ActionBtn DropBtn"
                                                    Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).DropItemCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <!-- Tooltip -->
                                        <ToolTip.Tip>
                                            <StackPanel MaxWidth="250" Spacing="5">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Foreground="{Binding QualityColor}"/>
                                                <TextBlock Text="{Binding QualityName}"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                                <Separator Margin="0,5"/>
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"/>
                                                <Separator Margin="0,5"/>
                                                <TextBlock Text="{Binding StatsSummary}"
                                                           FontSize="12"
                                                           Foreground="#4A90E2"/>
                                                <TextBlock Text="{Binding BonusesDisplay}"
                                                           FontSize="11"
                                                           Foreground="#FFD700"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </ToolTip.Tip>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Consumables Header -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,15,0,10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Consumables" Classes="SectionHeader" Margin="0"/>
                    <TextBlock Text="{Binding ConsumablesCountDisplay}"
                               FontSize="14"
                               Foreground="#888888"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Consumables Grid -->
            <Border Grid.Row="3" Classes="Section">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ConsumableItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="ItemCard" Width="180">
                                    <StackPanel Spacing="6">
                                        <!-- Item Header -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Background="#3C3C3C"
                                                    Width="28"
                                                    Height="28"
                                                    CornerRadius="4">
                                                <TextBlock Text="C"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding QualityColor}"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="12"
                                                           Foreground="{Binding QualityColor}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TypeDisplay}"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Effects -->
                                        <TextBlock Text="{Binding EffectsDisplay}"
                                                   FontSize="11"
                                                   Foreground="#228B22"
                                                   TextWrapping="Wrap"/>

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,4,0,0">
                                            <Button Content="Use"
                                                    Classes="ActionBtn UseBtn"
                                                    Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).UseConsumableCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Drop"
                                                    Classes="ActionBtn DropBtn"
                                                    Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).DropItemCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <!-- Tooltip -->
                                        <ToolTip.Tip>
                                            <StackPanel MaxWidth="250" Spacing="5">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Foreground="{Binding QualityColor}"/>
                                                <Separator Margin="0,5"/>
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"/>
                                                <Separator Margin="0,5"/>
                                                <TextBlock Text="{Binding EffectsDisplay}"
                                                           FontSize="12"
                                                           Foreground="#228B22"/>
                                            </StackPanel>
                                        </ToolTip.Tip>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>

</UserControl>
