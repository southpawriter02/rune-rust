<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RuneAndRust.DesktopUI.Views.SpriteDemoView"
             x:DataType="vm:SpriteDemoViewModel">

    <Design.DataContext>
        <vm:SpriteDemoViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="#1A1A1A">

        <!-- Header with Back Button -->
        <Border Grid.Row="0" Background="#2C2C2C" Padding="20,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Content="Back"
                        Command="{Binding BackCommand}"
                        Width="80"
                        HorizontalContentAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Description and Controls -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Margin="0,10,0,20">

            <TextBlock Text="{Binding Description}"
                       FontSize="16"
                       VerticalAlignment="Center"/>

            <TextBlock Text="Scale:"
                       VerticalAlignment="Center"/>

            <Slider Minimum="1"
                    Maximum="8"
                    Value="{Binding Scale}"
                    Width="200"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>

            <TextBlock Text="{Binding Scale, StringFormat='{}{0}x'}"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       MinWidth="30"/>

        </StackPanel>

        <!-- Sprite Grid -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding AvailableSprites}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#404040"
                                BorderThickness="1"
                                Padding="10"
                                Margin="10"
                                Background="#2A2A2A"
                                CornerRadius="4">
                            <StackPanel Spacing="8">

                                <!-- Sprite Name -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="150"/>

                                <!-- Sprite Display (Placeholder - will render via code-behind) -->
                                <Border Background="#1A1A1A"
                                        BorderBrush="#606060"
                                        BorderThickness="1"
                                        Padding="8"
                                        HorizontalAlignment="Center">
                                    <Canvas Width="{Binding Width}"
                                            Height="{Binding Height}"
                                            Tag="{Binding Bitmap}"
                                            Name="SpriteCanvas"/>
                                </Border>

                                <!-- Size Info -->
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="10"
                                           Opacity="0.7">
                                    <Run Text="{Binding Width}"/>
                                    <Run Text="×"/>
                                    <Run Text="{Binding Height}"/>
                                    <Run Text="px"/>
                                </TextBlock>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer Info -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Margin="0,20,0,20">

            <TextBlock Text="Sprite Format: 16×16 pixel art with palette"
                       Opacity="0.6"/>

            <TextBlock Text="•"
                       Opacity="0.6"/>

            <TextBlock Text="v0.43.2 - Sprite System &amp; Asset Pipeline"
                       Opacity="0.6"/>

        </StackPanel>

    </Grid>

</UserControl>
