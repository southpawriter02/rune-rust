<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             xmlns:conv="using:RuneAndRust.DesktopUI.Converters"
             x:Class="RuneAndRust.DesktopUI.Views.SaveLoadView"
             x:DataType="vm:SaveLoadViewModel">

    <Design.DataContext>
        <vm:SaveLoadViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <conv:SaveIconConverter x:Key="SaveIconConverter"/>
        <conv:SelectedBackgroundConverter x:Key="SelectedBackgroundConverter"/>
        <conv:SelectedBorderConverter x:Key="SelectedBorderConverter"/>
        <conv:SaveDateFormatConverter x:Key="SaveDateFormatConverter"/>
        <conv:PlayTimeFormatConverter x:Key="PlayTimeFormatConverter"/>
        <conv:ClassColorConverter x:Key="ClassColorConverter"/>
        <conv:LegendColorConverter x:Key="LegendColorConverter"/>
        <conv:SaveTypeLabelConverter x:Key="SaveTypeLabelConverter"/>
        <conv:SaveTypeLabelColorConverter x:Key="SaveTypeLabelColorConverter"/>
        <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Background="#1A1A1A">
        <!-- Header -->
        <Border Grid.Row="0" Background="#2C2C2C" Padding="20,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Content="Back"
                        Command="{Binding BackCommand}"
                        Width="80"
                        HorizontalContentAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Save / Load Game"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding SaveCount, StringFormat='{}{0} saves'}"
                               Foreground="#888888"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,380" Margin="20">
            <!-- Save Files List -->
            <Border Grid.Column="0"
                    Background="#2C2C2C"
                    Padding="20"
                    Margin="0,0,15,0"
                    CornerRadius="8">
                <Grid RowDefinitions="Auto,*">
                    <!-- List Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,15">
                        <TextBlock Grid.Column="0"
                                   Text="Save Files"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Grid.Column="1"
                                Content="Refresh"
                                Command="{Binding RefreshSavesCommand}"
                                Padding="12,6"/>
                    </Grid>

                    <!-- Save Files ScrollViewer -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SaveFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:SaveFileViewModel">
                                    <Border Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}"
                                            BorderBrush="{Binding IsSelected, Converter={StaticResource SelectedBorderConverter}}"
                                            BorderThickness="2"
                                            Padding="15"
                                            Margin="0,0,0,8"
                                            CornerRadius="6"
                                            Cursor="Hand"
                                            PointerPressed="OnSaveFilePressed">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Save Type Icon -->
                                            <Border Grid.Column="0"
                                                    Background="#3C3C3C"
                                                    CornerRadius="4"
                                                    Padding="10"
                                                    Margin="0,0,15,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding IsAutoSave, Converter={StaticResource SaveIconConverter}}"
                                                           FontSize="24"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Save Info -->
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <!-- Save Name Row -->
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding SaveName}"
                                                               FontWeight="Bold"
                                                               FontSize="16"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding $self.DataContext, Converter={StaticResource SaveTypeLabelConverter}}"
                                                               FontSize="11"
                                                               Foreground="{Binding $self.DataContext, Converter={StaticResource SaveTypeLabelColorConverter}}"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding IsAutoSave}"/>
                                                    <TextBlock Text="[QUICK]"
                                                               FontSize="11"
                                                               Foreground="#FFD700"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding IsQuickSave}"/>
                                                </StackPanel>

                                                <!-- Character Info -->
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding CharacterName}"
                                                               FontSize="13"
                                                               Foreground="#CCCCCC"/>
                                                    <TextBlock Text="-"
                                                               FontSize="13"
                                                               Foreground="#666666"/>
                                                    <TextBlock Text="{Binding CharacterClass}"
                                                               FontSize="13"
                                                               Foreground="{Binding CharacterClass, Converter={StaticResource ClassColorConverter}}"/>
                                                </StackPanel>

                                                <!-- Progress Info -->
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock FontSize="12" Foreground="#888888">
                                                        <Run Text="Floor "/>
                                                        <Run Text="{Binding CurrentFloor}" Foreground="#4A90E2"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="#888888">
                                                        <Run Text="Legend "/>
                                                        <Run Text="{Binding Legend}" Foreground="{Binding Legend, Converter={StaticResource LegendColorConverter}}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="Boss Defeated"
                                                               FontSize="11"
                                                               Foreground="#FFD700"
                                                               IsVisible="{Binding BossDefeated}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Date/Time Info -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding SaveDate, Converter={StaticResource SaveDateFormatConverter}}"
                                                           FontSize="12"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding PlayTime, Converter={StaticResource PlayTimeFormatConverter}}"
                                                           FontSize="11"
                                                           Foreground="#4A90E2"
                                                           HorizontalAlignment="Right"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Actions Sidebar -->
            <Border Grid.Column="1"
                    Background="#2C2C2C"
                    Padding="20"
                    CornerRadius="8">
                <StackPanel Spacing="20">
                    <!-- Save Game Section -->
                    <Border Background="#1C1C1C" Padding="15" CornerRadius="6">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Save Game"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBox Text="{Binding NewSaveName}"
                                     Watermark="Enter save name..."
                                     Height="40"
                                     FontSize="14"/>

                            <Button Content="Save"
                                    Command="{Binding SaveGameCommand}"
                                    Height="45"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Background="#4A90E2"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Load Game Section -->
                    <Border Background="#1C1C1C" Padding="15" CornerRadius="6">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Load Game"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Select a save file from the list to load it"
                                       FontSize="12"
                                       Foreground="#888888"
                                       TextWrapping="Wrap"/>

                            <!-- Selected Save Preview -->
                            <Border Background="#2C2C2C"
                                    Padding="10"
                                    CornerRadius="4"
                                    IsVisible="{Binding HasSelectedSave}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding SelectedSave.SaveName}"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding SelectedSave.CharacterSummary}"
                                               FontSize="12"
                                               Foreground="#CCCCCC"/>
                                </StackPanel>
                            </Border>

                            <Button Content="Load"
                                    Command="{Binding LoadGameCommand}"
                                    Height="45"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Background="#32CD32"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Delete Save Section -->
                    <Border Background="#1C1C1C" Padding="15" CornerRadius="6">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Delete Save"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#DC143C"/>

                            <TextBlock Text="This action cannot be undone"
                                       FontSize="11"
                                       Foreground="#888888"/>

                            <Button Content="Delete"
                                    Command="{Binding DeleteSaveCommand}"
                                    Height="45"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Background="#8B0000"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="#3C3C3C" Margin="0,5"/>

                    <!-- Quick Actions Section -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Quick Actions"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#CCCCCC"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Content="F5 Quick Save"
                                    Command="{Binding QuickSaveCommand}"
                                    Height="38"
                                    HorizontalContentAlignment="Center"
                                    FontSize="12"/>
                            <Button Grid.Column="1"
                                    Content="F9 Quick Load"
                                    Command="{Binding QuickLoadCommand}"
                                    Height="38"
                                    HorizontalContentAlignment="Center"
                                    FontSize="12"
                                    IsEnabled="{Binding HasQuickSave}"/>
                        </Grid>

                        <TextBlock Text="Quick save/load available anytime during gameplay"
                                   FontSize="10"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer Status Bar -->
        <Border Grid.Row="2" Background="#2C2C2C" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Status Message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"/>

                <!-- Auto-Save Indicator -->
                <Border Grid.Column="1"
                        Background="#2A4A2A"
                        Padding="12,6"
                        CornerRadius="4"
                        IsVisible="{Binding ShowAutoSaveIndicator}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Auto-saving..."
                                   FontSize="13"
                                   Foreground="#4CAF50"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>
