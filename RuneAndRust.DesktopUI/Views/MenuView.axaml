<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RuneAndRust.DesktopUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RuneAndRust.DesktopUI.Views.MenuView"
             x:DataType="vm:MenuViewModel">

    <Design.DataContext>
        <vm:MenuViewModel/>
    </Design.DataContext>

    <!-- Menu layout -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Title area -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,40,0,20">
            <TextBlock Text="{Binding Title}"
                       FontSize="48"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Version}"
                       FontSize="16"
                       Opacity="0.7"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Menu buttons -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="15">

            <Button Content="New Game"
                    Command="{Binding NewGameCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

            <Button Content="Continue Game"
                    Command="{Binding ContinueGameCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

            <Button Content="Load Game"
                    Command="{Binding LoadGameCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

            <Button Content="Settings"
                    Command="{Binding SettingsCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

            <Button Content="Achievements"
                    Command="{Binding AchievementsCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

            <Button Content="Sprite Demo"
                    Command="{Binding SpriteDemoCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

            <Button Content="Exit"
                    Command="{Binding ExitCommand}"
                    Width="300"
                    Height="50"
                    FontSize="18"/>

        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Text="© 2025 Rune &amp; Rust - v0.43.2 Sprite System &amp; Asset Pipeline"
                   HorizontalAlignment="Center"
                   Opacity="0.5"
                   Margin="0,0,0,20"/>

    </Grid>

</UserControl>
